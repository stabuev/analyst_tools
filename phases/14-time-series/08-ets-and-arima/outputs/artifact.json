{
  "name": "statsmodels-forecast-runner",
  "type": "cli",
  "path": "outputs/statsmodels_forecast_runner.py",
  "description": "Fits predeclared ETS and ARIMA statsmodels candidates from cutoff-safe training rows, captures convergence and warning diagnostics, and compares the emitted forecast shape against the primary seasonal-naive baseline.",
  "usage": "python outputs/statsmodels_forecast_runner.py --series ../02-resampling/outputs/daily_resampled.csv --calendar ../data/tiny/calendar.csv --scenario ../data/tiny/forecast_scenario.json --cutoff-contract ../05-temporal-leakage/outputs/cutoff_contract.json --baseline-report ../06-forecast-baselines/outputs/baseline_report.json --baseline-forecasts ../06-forecast-baselines/outputs/baseline_forecasts.csv --decomposition-report ../07-decomposition/outputs/decomposition_report.json --spec ../data/tiny/statsmodels_model_spec.json --output-dir outputs"
}
