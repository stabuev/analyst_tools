{
  "version": "1.0.0",
  "metric_id": "active_retention",
  "cohort_unit": "user_id",
  "start_source": "registered_at",
  "return_event_names": [
    "app_open",
    "feature_value_seen",
    "paywall_viewed",
    "trial_started",
    "subscription_started",
    "order_paid",
    "support_ticket_created"
  ],
  "age_days": [1, 2, 3, 4, 5, 6, 7],
  "retention_modes": ["exact_day", "on_or_after"],
  "business_timezone": "Europe/Moscow",
  "exclude_test_users": true,
  "count_start_day_as_return": false,
  "incomplete_window_policy": "blank_rate",
  "observation_end_date": "auto",
  "description": "Daily retention from registered cohorts to active return events, with exact-day and on-or-after semantics."
}
