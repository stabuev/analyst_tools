{
  "version": "1.0.0",
  "product_question": "После изменения onboarding и paywall продолжать rollout, откатить изменение или поставить следующий проверяемый шаг?",
  "max_late_minutes": 1440,
  "identity_fields": ["user_id", "anonymous_id"],
  "events": [
    {
      "event_name": "app_open",
      "version": 1,
      "owner": "activation",
      "description": "Пользователь открыл продукт в новой или восстановленной сессии.",
      "trigger": "client app foreground or web session start",
      "identity_policy": "anonymous_or_user",
      "required_properties": ["source"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": [],
      "source": "client"
    },
    {
      "event_name": "signup_started",
      "version": 1,
      "owner": "growth",
      "description": "Пользователь начал регистрацию.",
      "trigger": "signup form opened or first signup step submitted",
      "identity_policy": "anonymous_or_user",
      "required_properties": ["entry"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": [],
      "source": "client"
    },
    {
      "event_name": "account_created",
      "version": 1,
      "owner": "growth",
      "description": "Регистрация пользователя завершена и выдан стабильный user_id.",
      "trigger": "account creation committed by backend",
      "identity_policy": "known_user",
      "required_properties": ["method"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["activation_rate_7d", "support_ticket_rate_7d"],
      "source": "server"
    },
    {
      "event_name": "onboarding_started",
      "version": 1,
      "owner": "growth",
      "description": "Пользователь вошел в первый шаг onboarding.",
      "trigger": "first onboarding screen shown",
      "identity_policy": "known_user",
      "required_properties": [],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["onboarding_completion_rate"],
      "source": "client"
    },
    {
      "event_name": "onboarding_completed",
      "version": 1,
      "owner": "growth",
      "description": "Пользователь завершил обязательные шаги onboarding.",
      "trigger": "last required onboarding step completed",
      "identity_policy": "known_user",
      "required_properties": ["steps"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["onboarding_completion_rate"],
      "source": "client"
    },
    {
      "event_name": "feature_value_seen",
      "version": 1,
      "owner": "activation",
      "description": "Пользователь увидел ключевую ценность продукта.",
      "trigger": "first valuable feature result rendered",
      "identity_policy": "known_user",
      "required_properties": ["feature"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["activation_rate_7d"],
      "source": "client"
    },
    {
      "event_name": "paywall_viewed",
      "version": 1,
      "owner": "monetization",
      "description": "Пользователь увидел экран paywall.",
      "trigger": "paywall screen rendered",
      "identity_policy": "known_user",
      "required_properties": ["variant"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["paywall_to_trial_conversion_7d"],
      "source": "client"
    },
    {
      "event_name": "trial_started",
      "version": 1,
      "owner": "monetization",
      "description": "Пользователь начал пробный период.",
      "trigger": "trial entitlement created by backend",
      "identity_policy": "known_user",
      "required_properties": ["plan"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["paywall_to_trial_conversion_7d"],
      "source": "server"
    },
    {
      "event_name": "subscription_started",
      "version": 1,
      "owner": "monetization",
      "description": "Создан платный или trial-период подписки.",
      "trigger": "subscription object created by billing backend",
      "identity_policy": "known_user",
      "required_properties": ["plan"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["subscription_cancel_rate_14d"],
      "source": "server"
    },
    {
      "event_name": "order_paid",
      "version": 1,
      "owner": "marketplace",
      "description": "Пользователь оплатил заказ маркетплейса.",
      "trigger": "payment captured by backend",
      "identity_policy": "known_user",
      "required_properties": ["order_id"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": [],
      "source": "server"
    },
    {
      "event_name": "subscription_cancelled",
      "version": 1,
      "owner": "monetization",
      "description": "Пользователь отменил подписку.",
      "trigger": "subscription status changed to cancelled",
      "identity_policy": "known_user",
      "required_properties": ["reason"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["subscription_cancel_rate_14d"],
      "source": "server"
    },
    {
      "event_name": "support_ticket_created",
      "version": 1,
      "owner": "support",
      "description": "Пользователь создал обращение в поддержку.",
      "trigger": "support ticket accepted by support system",
      "identity_policy": "known_user",
      "required_properties": ["category"],
      "optional_properties": [],
      "allowed_platforms": ["web", "ios", "android"],
      "app_version_policy": "mobile_required",
      "used_by_metrics": ["support_ticket_rate_7d"],
      "source": "server"
    }
  ]
}
