{
  "metrics": [
    {
      "metric_id": "activation_rate_7d",
      "question": "Какая доля новых реальных пользователей увидела ценность продукта за семь дней после регистрации?",
      "owner": "product",
      "role": "outcome",
      "grain": "user_id",
      "eligible_population": "registered non-test users with a complete 7-day observation window",
      "numerator": "users with feature_value_seen within 7 days after account_created",
      "denominator": "registered non-test users in the cohort",
      "window": "7 days after account_created",
      "filters": ["is_test_user = false"],
      "dimensions": ["platform", "acquisition_channel"],
      "expected_direction": "up",
      "guardrails": ["support_ticket_rate_7d", "subscription_cancel_rate_14d"],
      "known_failure_modes": ["incomplete observation window", "duplicate event delivery", "test users"],
      "source_tables": ["users", "events"],
      "validation_checks": ["deduplicate events by event_id", "exclude test users", "require complete 7-day window"]
    },
    {
      "metric_id": "onboarding_completion_rate",
      "question": "Какая доля начавших onboarding завершает его в той же сессии?",
      "owner": "growth",
      "role": "input",
      "grain": "session_id",
      "eligible_population": "sessions with onboarding_started",
      "numerator": "sessions with onboarding_completed after onboarding_started",
      "denominator": "sessions with onboarding_started",
      "window": "same session",
      "filters": ["is_test_user = false"],
      "dimensions": ["platform", "app_version"],
      "expected_direction": "up",
      "guardrails": ["support_ticket_rate_7d"],
      "known_failure_modes": ["loose event ordering", "session split at local midnight"],
      "source_tables": ["events", "sessions", "users"],
      "validation_checks": ["strict order inside session", "known event names", "session_id present"]
    },
    {
      "metric_id": "paywall_to_trial_conversion_7d",
      "question": "Какая доля пользователей, увидевших paywall, начинает trial за семь дней?",
      "owner": "monetization",
      "role": "input",
      "grain": "user_id",
      "eligible_population": "non-test users with paywall_viewed",
      "numerator": "users with trial_started within 7 days after first paywall_viewed",
      "denominator": "users with first paywall_viewed",
      "window": "7 days after first paywall_viewed",
      "filters": ["is_test_user = false"],
      "dimensions": ["platform", "app_version", "acquisition_channel"],
      "expected_direction": "up",
      "guardrails": ["subscription_cancel_rate_14d", "support_ticket_rate_7d"],
      "known_failure_modes": ["repeat paywall views", "late trial event", "android release regression"],
      "source_tables": ["events", "users"],
      "validation_checks": ["first paywall per user", "deduplicate events by event_id", "require complete 7-day window"]
    },
    {
      "metric_id": "support_ticket_rate_7d",
      "question": "Какая доля новых пользователей создает обращение в поддержку за семь дней?",
      "owner": "support",
      "role": "guardrail",
      "grain": "user_id",
      "eligible_population": "registered non-test users with a complete 7-day observation window",
      "numerator": "users with at least one support ticket within 7 days after account_created",
      "denominator": "registered non-test users in the cohort",
      "window": "7 days after account_created",
      "filters": ["is_test_user = false"],
      "dimensions": ["platform", "category"],
      "expected_direction": "up_is_bad",
      "guardrails": [],
      "known_failure_modes": ["ticket duplication", "support system delay", "test users"],
      "source_tables": ["users", "events", "support_tickets"],
      "validation_checks": ["ticket_id unique", "join tickets to users by user_id", "exclude test users"]
    },
    {
      "metric_id": "subscription_cancel_rate_14d",
      "question": "Какая доля начавших подписку отменяет ее за четырнадцать дней?",
      "owner": "monetization",
      "role": "guardrail",
      "grain": "subscription_id",
      "eligible_population": "started subscriptions with a complete 14-day observation window",
      "numerator": "subscriptions with subscription_cancelled or cancelled subscription status within 14 days",
      "denominator": "started subscriptions",
      "window": "14 days after subscription_started",
      "filters": ["is_test_user = false"],
      "dimensions": ["plan", "platform"],
      "expected_direction": "up_is_bad",
      "guardrails": [],
      "known_failure_modes": ["refund treated as cancellation", "incomplete observation window"],
      "source_tables": ["subscriptions", "events", "users"],
      "validation_checks": ["subscription_id unique", "complete 14-day window", "cancel event belongs to subscription owner"]
    }
  ]
}
