{
  "version": "1.0.0",
  "description": "Детерминированные продуктовые события, сессии, подписки, платежи, обращения и релизы для фазы 08.",
  "generator": "generate_data.py",
  "profiles": {
    "tiny": {
      "description": "Валидный baseline для ручной сверки деревьев метрик, event model и первых продуктовых расчетов.",
      "tracked": true,
      "rows": {
        "users": 8,
        "sessions": 8,
        "events": 41,
        "subscriptions": 4,
        "orders": 5,
        "support_tickets": 3,
        "release_calendar": 2
      }
    },
    "sample": {
      "description": "Локальный профиль для недельных трендов, сегментов, когорт и аномалий.",
      "tracked": false,
      "rows": {
        "users": 250
      },
      "seed": 20260619
    }
  },
  "tables": {
    "users": {
      "file": "users.csv",
      "grain": "Одна строка на зарегистрированного пользователя.",
      "primary_key": ["user_id"]
    },
    "sessions": {
      "file": "sessions.csv",
      "grain": "Одна нормализованная пользовательская сессия.",
      "primary_key": ["session_id"],
      "foreign_keys": [{"columns": ["user_id"], "references": "users.user_id"}]
    },
    "events": {
      "file": "events.csv",
      "grain": "Одно клиентское или серверное событие.",
      "primary_key": ["event_id"],
      "foreign_keys": [
        {"columns": ["user_id"], "references": "users.user_id"},
        {"columns": ["session_id"], "references": "sessions.session_id"}
      ]
    },
    "subscriptions": {
      "file": "subscriptions.csv",
      "grain": "Один период подписки пользователя.",
      "primary_key": ["subscription_id"],
      "foreign_keys": [{"columns": ["user_id"], "references": "users.user_id"}]
    },
    "orders": {
      "file": "orders.csv",
      "grain": "Один платеж или заказ маркетплейса.",
      "primary_key": ["order_id"],
      "foreign_keys": [{"columns": ["user_id"], "references": "users.user_id"}]
    },
    "support_tickets": {
      "file": "support_tickets.csv",
      "grain": "Одно обращение пользователя в поддержку.",
      "primary_key": ["ticket_id"],
      "foreign_keys": [{"columns": ["user_id"], "references": "users.user_id"}]
    },
    "release_calendar": {
      "file": "release_calendar.csv",
      "grain": "Один релиз продукта на платформе.",
      "primary_key": ["release_id"]
    }
  },
  "known_failure_modes": [
    "duplicate event delivery",
    "late arrival after daily cutoff",
    "anonymous-to-user identity merge",
    "event rename or version drift",
    "test users and internal traffic",
    "incomplete observation windows",
    "composition effect by acquisition channel",
    "android release regression",
    "many-to-many revenue join"
  ]
}
