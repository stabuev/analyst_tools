{
  "version": "1.0.0",
  "analysis_periods": [
    {
      "period_id": "baseline",
      "date_from": "2026-06-01",
      "date_to": "2026-06-03"
    },
    {
      "period_id": "comparison",
      "date_from": "2026-06-04",
      "date_to": "2026-06-08"
    }
  ],
  "business_timezone": "Europe/Moscow",
  "observation_end_date": "2026-06-22",
  "exclude_test_users": true,
  "complete_window_policy": "blank_metric",
  "overall_decision_rules": {
    "any_breached": "block_rollout",
    "any_watch": "investigate",
    "all_ok": "guardrails_ok"
  },
  "guardrails": [
    {
      "metric_id": "support_ticket_rate_7d",
      "source": "support_tickets",
      "unit": "user_id",
      "start_source": "users.registered_at",
      "event_timestamp": "support_tickets.created_at",
      "window_days": 7,
      "risk_direction": "up_is_bad",
      "max_rate": 0.4,
      "max_delta": 0.2,
      "metric_spec_required": true,
      "denominator": "registered_non_test_users",
      "numerator": "users_with_support_ticket"
    },
    {
      "metric_id": "subscription_cancel_rate_14d",
      "source": "subscriptions",
      "unit": "subscription_id",
      "start_source": "subscriptions.started_at",
      "event_timestamp": "subscriptions.ended_at",
      "window_days": 14,
      "risk_direction": "up_is_bad",
      "max_rate": 0.25,
      "max_delta": 0.2,
      "metric_spec_required": true,
      "denominator": "started_subscriptions",
      "numerator": "cancelled_subscriptions"
    },
    {
      "metric_id": "refund_rate_7d",
      "source": "orders",
      "unit": "order_id",
      "start_source": "orders.ordered_at",
      "event_timestamp": "orders.ordered_at",
      "window_days": 7,
      "risk_direction": "up_is_bad",
      "max_rate": 0.2,
      "max_delta": 0.15,
      "metric_spec_required": false,
      "denominator": "settled_orders",
      "numerator": "refunded_orders",
      "denominator_statuses": ["paid", "refunded"],
      "refund_statuses": ["refunded"],
      "expected_currency": "RUB"
    }
  ],
  "description": "Calculate product guardrail metrics with explicit risk direction, thresholds and complete-window policy before making a rollout decision."
}
