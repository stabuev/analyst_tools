{
  "version": "1.0.0",
  "description": "Детерминированные грязные таблицы для ручной проверки pandas-преобразований.",
  "generator": "generate_tiny.py",
  "tables": {
    "users": {
      "file": "tiny/users.csv",
      "grain": "Одна строка на пользователя.",
      "primary_key": [
        "user_id"
      ],
      "time_range": {
        "column": "registered_at",
        "min": "2026-01-02T08:15:00+03:00",
        "max": "2026-01-10T09:00:00+01:00"
      },
      "columns": {
        "user_id": {
          "semantic_type": "string identifier",
          "nullable": false
        },
        "registered_at": {
          "semantic_type": "timezone-aware timestamp",
          "nullable": false
        },
        "country": {
          "semantic_type": "ISO-like country code",
          "nullable": true
        },
        "plan": {
          "semantic_type": "subscription category",
          "nullable": false
        },
        "is_marketing_opt_in": {
          "semantic_type": "nullable boolean",
          "nullable": true
        }
      },
      "generation_rules": [
        "Порядок строк и значения фиксированы в generate_tiny.py.",
        "Идентификаторы пользователей уникальны."
      ],
      "known_defects": [
        "country содержит пробелы и пропуск.",
        "plan использует разный регистр.",
        "is_marketing_opt_in содержит пропуск."
      ]
    },
    "orders": {
      "file": "tiny/orders.csv",
      "grain": "Одна строка на заказ.",
      "primary_key": [
        "order_id"
      ],
      "time_range": {
        "column": "ordered_at",
        "min": "2026-02-01T10:00:00+03:00",
        "max": "2026-02-06T09:30:00+01:00"
      },
      "columns": {
        "order_id": {
          "semantic_type": "string identifier",
          "nullable": false
        },
        "user_id": {
          "semantic_type": "foreign key to users.user_id",
          "nullable": false
        },
        "ordered_at": {
          "semantic_type": "timezone-aware timestamp",
          "nullable": true
        },
        "status": {
          "semantic_type": "order status category",
          "nullable": false
        },
        "currency": {
          "semantic_type": "ISO currency code",
          "nullable": false
        },
        "amount": {
          "semantic_type": "decimal amount in native currency",
          "nullable": true
        }
      },
      "generation_rules": [
        "order_id уникален, а порядок строк фиксирован.",
        "Суммы нельзя агрегировать между валютами без курса конвертации."
      ],
      "known_defects": [
        "ordered_at содержит разные UTC offsets и один пропуск.",
        "status содержит пробелы и разный регистр.",
        "amount отсутствует у незавершенного заказа.",
        "U999 отсутствует в users и моделирует удаленного пользователя."
      ]
    },
    "order_items": {
      "file": "tiny/order_items.csv",
      "grain": "Одна строка на товарную позицию заказа.",
      "primary_key": [
        "order_id",
        "product_id"
      ],
      "time_range": {
        "source": "Наследуется от orders.ordered_at через order_id."
      },
      "columns": {
        "order_id": {
          "semantic_type": "foreign key to orders.order_id",
          "nullable": false
        },
        "product_id": {
          "semantic_type": "string identifier",
          "nullable": false
        },
        "category": {
          "semantic_type": "product category",
          "nullable": false
        },
        "quantity": {
          "semantic_type": "positive integer",
          "nullable": false
        },
        "unit_price": {
          "semantic_type": "decimal amount in order currency",
          "nullable": false
        }
      },
      "generation_rules": [
        "Пара order_id и product_id уникальна.",
        "Сумма quantity * unit_price совпадает с orders.amount для заполненных сумм."
      ],
      "known_defects": [
        "category содержит пробелы, разные регистры и два написания add-on.",
        "Заказ O1001 имеет две позиции: наивный join размножит orders.amount."
      ]
    }
  }
}
