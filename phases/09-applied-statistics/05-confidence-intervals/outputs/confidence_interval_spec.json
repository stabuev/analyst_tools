{
  "version": "1.0.0",
  "question_id": "formula_confidence_intervals_for_user_level_metrics",
  "target_population": "Eligible non-test registered users with a complete seven-day observation window.",
  "sampling_unit": "user_id",
  "observation_filter": {
    "outcome_observed_column": "outcome_observed",
    "observed_days_column": "observed_days",
    "required_observed_days": 7
  },
  "coverage_simulation": {
    "seed": 20260621,
    "n_simulations": 2500,
    "sample_size": 5,
    "source": "eligible_population_with_replacement"
  },
  "intervals": [
    {
      "interval_id": "activation_rate_normal_95",
      "parameter_id": "activation_rate",
      "description": "Normal approximation interval for the seven-day activation proportion.",
      "sample_metric_column": "activated_7d",
      "population_metric_column": "true_activated_7d",
      "value_type": "boolean",
      "method": "normal_proportion",
      "confidence_level": 0.95,
      "minimum_n": 3,
      "minimum_successes": 2,
      "minimum_failures": 2,
      "distribution_card_metric_id": "activation_7d",
      "known_limitations": [
        "Tiny sample has weak success/failure counts.",
        "Normal approximation is checked by coverage simulation."
      ]
    },
    {
      "interval_id": "first_order_amount_t_95",
      "parameter_id": "first_order_amount_rub_mean",
      "description": "Student t interval for mean first order amount, including zero revenue.",
      "sample_metric_column": "first_order_amount_rub",
      "population_metric_column": "true_first_order_amount_rub",
      "value_type": "numeric",
      "method": "t_mean",
      "confidence_level": 0.95,
      "minimum_n": 3,
      "distribution_card_metric_id": "first_order_amount_rub_positive",
      "known_limitations": [
        "Revenue is skewed and has zero mass.",
        "Formula interval is a diagnostic baseline before bootstrap."
      ]
    },
    {
      "interval_id": "support_tickets_normal_95",
      "parameter_id": "support_tickets_per_user",
      "description": "Normal approximation interval for support tickets per user.",
      "sample_metric_column": "support_tickets_7d",
      "population_metric_column": "true_support_tickets_7d",
      "value_type": "count",
      "method": "normal_mean",
      "confidence_level": 0.95,
      "minimum_n": 8,
      "distribution_card_metric_id": "support_tickets_7d",
      "known_limitations": [
        "Count outcome with small n should move to bootstrap or exact count model."
      ]
    }
  ]
}
