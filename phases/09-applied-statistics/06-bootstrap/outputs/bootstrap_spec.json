{
  "version": "1.0.0",
  "question_id": "bootstrap_intervals_for_user_level_statistics",
  "target_population": "Eligible non-test registered users with a complete seven-day observation window.",
  "sampling_unit": "user_id",
  "resampling_unit": "user_id",
  "paired": true,
  "seed": 20260622,
  "n_resamples": 2000,
  "confidence_level": 0.95,
  "observation_filter": {
    "outcome_observed_column": "outcome_observed",
    "observed_days_column": "observed_days",
    "required_observed_days": 7
  },
  "statistics": [
    {
      "statistic_id": "activation_rate_percentile",
      "parameter_id": "activation_rate",
      "metric_column": "activated_7d",
      "value_type": "boolean",
      "statistic": "mean",
      "method": "percentile",
      "distribution_card_metric_id": "activation_7d",
      "known_limitations": ["Wald interval under-covered in 09/05; percentile bootstrap is still fragile at n=5."]
    },
    {
      "statistic_id": "onboarding_seconds_median_basic",
      "parameter_id": "onboarding_seconds_median",
      "metric_column": "onboarding_seconds",
      "value_type": "numeric",
      "statistic": "median",
      "method": "basic",
      "distribution_card_metric_id": "onboarding_seconds",
      "known_limitations": ["Median bootstrap distribution is discrete in a tiny sample."]
    },
    {
      "statistic_id": "first_order_amount_mean_bca",
      "parameter_id": "first_order_amount_rub_mean",
      "metric_column": "first_order_amount_rub",
      "value_type": "numeric",
      "statistic": "mean",
      "method": "bca",
      "distribution_card_metric_id": "first_order_amount_rub_positive",
      "known_limitations": ["BCa is computed by SciPy but remains unstable with very small n and zero-inflated revenue."]
    }
  ]
}
