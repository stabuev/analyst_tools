{
  "version": "1.0.0",
  "adjustment_unit": "user_id",
  "method": "single_pre_treatment_covariate_cuped",
  "minimum_units_per_variant": 20,
  "minimum_abs_correlation": 0.05,
  "confidence_level": 0.95,
  "covariates": [
    {
      "name": "sessions_7d_pre",
      "source_table": "pre_experiment_metrics",
      "timing": "pre_treatment",
      "description": "Количество пользовательских сессий за семь дней до старта эксперимента."
    },
    {
      "name": "activation_7d_pre",
      "source_table": "pre_experiment_metrics",
      "timing": "pre_treatment",
      "description": "Бинарный флаг достижения value moment за семь дней до старта эксперимента."
    }
  ],
  "metrics": [
    {
      "metric_id": "activation_rate_7d",
      "enabled": true,
      "covariate": "sessions_7d_pre",
      "apply_to_decision": true
    },
    {
      "metric_id": "support_ticket_rate_7d",
      "enabled": true,
      "covariate": "activation_7d_pre",
      "apply_to_decision": true
    },
    {
      "metric_id": "subscription_cancel_rate_14d",
      "enabled": false,
      "skip_reason": "conditional subscription denominator is sparse in the tiny profile"
    },
    {
      "metric_id": "refund_rate_7d",
      "enabled": false,
      "skip_reason": "ratio metrics require paired numerator/denominator augmentation beyond this simple CUPED artifact"
    },
    {
      "metric_id": "paywall_to_trial_conversion_7d",
      "enabled": true,
      "covariate": "sessions_7d_pre",
      "apply_to_decision": false
    },
    {
      "metric_id": "realized_revenue_per_user_7d",
      "enabled": true,
      "covariate": "sessions_7d_pre",
      "apply_to_decision": false
    }
  ]
}
