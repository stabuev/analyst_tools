          {"type": "categorical_map", "field": "acquisition_channel", "values": {"paid_social": 0.2, "paid_search": 0.1, "organic": 0.0, "referral": -0.05}},
          {"type": "categorical_map", "field": "region_id", "values": {"north": 0.05, "south": 0.0}},
          {"type": "categorical_map", "field": "language", "values": {"ru": 0.0, "en": 0.05}}
        ]
      }
    ],
    "standardization": {
      "counterfactual_treatment_values": [1, 0],
      "population_estimands": ["ATE", "ATT"],
      "prediction_population": "same target-population rows under both treatment strategies"
    },
    "diagnostics": {
      "probability_bounds": [0.0, 1.0],
      "overlap_features": ["baseline_risk_score", "specialist_capacity"],
      "warn_if_prediction_outside_probability_bounds": true,
      "warn_if_counterfactual_outside_observed_support": true,
      "min_rows_per_parameter": 2.0
    }
  },
