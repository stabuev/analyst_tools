{
  "version": "1.0.0",
  "description": "Контракт CSV заказов с явными encoding, dialect, schema и null policy.",
  "file": "tiny/orders_semicolon_cp1251.csv",
  "grain": "Одна строка на заказ.",
  "encoding": "cp1251",
  "header": true,
  "dialect": {
    "delimiter": ";",
    "quotechar": "\"",
    "doublequote": true,
    "skipinitialspace": false
  },
  "null_values": [
    "",
    "NULL"
  ],
  "number_format": {
    "decimal": ",",
    "thousands": " "
  },
  "expected_rows": 5,
  "columns": {
    "order_id": {
      "type": "string",
      "nullable": false
    },
    "user_id": {
      "type": "string",
      "nullable": false
    },
    "ordered_at": {
      "type": "timestamp",
      "nullable": false
    },
    "amount": {
      "type": "decimal",
      "nullable": false
    },
    "currency": {
      "type": "string",
      "nullable": false
    },
    "comment": {
      "type": "string",
      "nullable": true
    }
  },
  "known_cases": [
    "Текст и заголовок закодированы в CP1251.",
    "Числа используют десятичную запятую и пробел как разделитель тысяч.",
    "Комментарий одной строки содержит разделитель внутри кавычек.",
    "NULL и пустая строка являются пропуском только по явной политике."
  ]
}
