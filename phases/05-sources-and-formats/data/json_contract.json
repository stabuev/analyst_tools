{
  "version": "1.0.0",
  "description": "Контракт нормализации вложенных событий и позиций.",
  "root": "events",
  "record_grain": ["event_id"],
  "record_fields": {
    "event_id": {"path": "event_id", "type": "string", "nullable": false},
    "user_id": {"path": "user.id", "type": "string", "nullable": false},
    "occurred_at": {"path": "occurred_at", "type": "timestamp", "nullable": false},
    "device_os": {"path": "context.device.os", "type": "string", "nullable": true},
    "screen": {"path": "context.screen", "type": "string", "nullable": false}
  },
  "array": {
    "path": "items",
    "grain": ["event_id", "item_position"],
    "fields": {
      "product_id": {"path": "product_id", "type": "string", "nullable": false},
      "quantity": {"path": "quantity", "type": "integer", "nullable": false},
      "price": {"path": "price", "type": "number", "nullable": false}
    }
  },
  "allowed_paths": [
    "context",
    "context.device",
    "context.device.os",
    "context.screen",
    "event_id",
    "items",
    "items[]",
    "items[].price",
    "items[].product_id",
    "items[].quantity",
    "occurred_at",
    "user",
    "user.id"
  ]
}
