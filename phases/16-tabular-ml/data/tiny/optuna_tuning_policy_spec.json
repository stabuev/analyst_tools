{
  "optuna_tuning_audit_id": "trial-churn-optuna-tuning-audit-v0",
  "problem_id": "trial-churn-risk-7d-before-end",
  "baseline_package_id": "trial-churn-ml-baseline-package-v0",
  "source_candidate_model_id": "catboost_depth2_native_categories_es_logloss",
  "tuned_candidate_model_id": "catboost_optuna_fixed_budget_logloss",
  "catboost_baseline_id": "trial-churn-catboost-baseline-v0",
  "early_stopping_audit_id": "trial-churn-early-stopping-audit-v0",
  "cost_sensitive_decision_audit_id": "trial-churn-cost-sensitive-decision-audit-v0",
  "fit_split": "train",
  "objective_split": "validation",
  "final_holdout_split": "test",
  "study": {
    "study_name": "trial_churn_catboost_fixed_budget_v0",
    "direction": "minimize",
    "objective_metric": "validation_logloss",
    "storage": "in_memory_for_lesson",
    "sampler": {
      "name": "GridSampler",
      "seed": 1609
    },
    "pruner": {
      "name": "NopPruner",
      "reason": "tiny fixed-grid lesson keeps every trial in the ledger"
    },
    "n_trials": 6,
    "max_trials_allowed": 10,
    "require_all_trials_in_ledger": true
  },
  "search_space": {
    "depth": {
      "type": "categorical",
      "values": [1, 2]
    },
    "learning_rate": {
      "type": "categorical",
      "values": [0.05, 0.2, 0.4]
    }
  },
  "fixed_catboost_params": {
    "iterations": 40,
    "l2_leaf_reg": 1.0,
    "loss_function": "Logloss",
    "eval_metric": "Logloss",
    "random_seed": 1609,
    "allow_writing_files": false,
    "verbose": false,
    "thread_count": 1,
    "bootstrap_type": "No",
    "random_strength": 0,
    "use_best_model": true,
    "od_type": "Iter",
    "od_wait": 3
  },
  "feature_contract": {
    "key": "snapshot_id",
    "numeric_features": [
      "sessions_14d",
      "active_days_14d",
      "support_tickets_14d",
      "revenue_30d",
      "days_since_signup",
      "had_support_ticket_14d"
    ],
    "categorical_features": [
      "plan_id",
      "platform",
      "country",
      "acquisition_channel"
    ],
    "missing_category_token": "__MISSING__"
  },
  "objective_policy": {
    "fit_data": "train",
    "selection_data": "validation",
    "forbid_objective_on_test": true,
    "forbid_test_metric_in_best_trial_selection": true,
    "log_secondary_validation_metrics": [
      "top_k_cost",
      "fixed_threshold_0_5_cost"
    ],
    "final_holdout_role": "final_once_only_evaluation_after_model_selection"
  },
  "cost_policy": {
    "false_positive_cost": 1.0,
    "false_negative_cost": 5.0,
    "max_actions": 2,
    "top_k_tie_breaker": [
      "score_desc",
      "snapshot_id_asc"
    ]
  },
  "decision_policy": {
    "best_trial_may_improve_objective_but_not_override_cost_gate": true,
    "promotion_requires_separate_calibration_and_cost_sensitive_gate": true,
    "outcome_if_valid": "tuned_candidate_ready_for_mlflow_tracking",
    "next_lesson_readiness": "ready_for_mlflow_lesson"
  },
  "warning_policy": {
    "warn_on_tiny_trial_budget": true,
    "warn_if_upstream_candidate_not_promoted": true,
    "warn_if_best_trial_cost_not_better_than_baseline_cost": true,
    "require_no_test_objective_boundary": true
  },
  "output": {
    "report_file": "optuna_tuning_report.json",
    "trial_ledger_file": "optuna_trial_ledger.csv",
    "best_trial_trace_file": "optuna_best_trial_trace.csv",
    "prediction_file": "optuna_tuned_predictions.csv",
    "search_space_audit_file": "optuna_search_space_audit.csv",
    "objective_audit_file": "optuna_objective_audit.csv",
    "serialized_spec_file": "optuna_tuning_serialized_spec.json"
  }
}
