{
  "shap_explanation_audit_id": "trial-churn-shap-explanation-audit-v0",
  "problem_id": "trial-churn-risk-7d-before-end",
  "catboost_baseline_id": "trial-churn-catboost-baseline-v0",
  "source_catboost_model_id": "catboost_depth2_native_categories",
  "early_stopping_model_id": "catboost_depth2_native_categories_es_logloss",
  "early_stopping_audit_id": "trial-churn-early-stopping-audit-v0",
  "categorical_audit_id": "trial-churn-categorical-feature-audit-v0",
  "built_in_importance_audit_id": "trial-churn-built-in-importance-audit-v0",
  "permutation_importance_audit_id": "trial-churn-permutation-importance-audit-v0",
  "fit_split": "train",
  "explain_split": "validation",
  "final_holdout_split": "test",
  "explainer": {
    "library": "shap",
    "class": "TreeExplainer",
    "model_output": "raw",
    "output_space": "raw_margin",
    "feature_perturbation": "tree_path_dependent",
    "background_mode": "catboost_tree_path_dependent_training_path_counts",
    "external_background_data_passed": false,
    "background_split": "train",
    "background_sample_policy": "all_train_rows_recorded_as_reference; CatBoost categorical splits require no external background data for TreeExplainer",
    "background_random_state": 1606
  },
  "additivity": {
    "enabled": true,
    "expected_value_source": "TreeExplainer.expected_value",
    "target_prediction_type": "RawFormulaVal",
    "absolute_error_tolerance": 1e-09
  },
  "local_explanations": {
    "snapshot_ids": ["S005", "S006", "S007"],
    "top_k_features": 3,
    "include_zero_contributions": false
  },
  "global_summary": {
    "aggregation_split": "validation",
    "metric": "mean_abs_shap",
    "rank_tie_breaker": "feature_order"
  },
  "feature_name_policy": {
    "require_exact_feature_order": true,
    "expected_feature_order": [
      "sessions_14d",
      "active_days_14d",
      "support_tickets_14d",
      "revenue_30d",
      "days_since_signup",
      "had_support_ticket_14d",
      "plan_id",
      "platform",
      "country",
      "acquisition_channel"
    ]
  },
  "interpretation_policy": {
    "claim": "Tree SHAP decomposes this CatBoost model's raw margin prediction on the validation rows into feature contributions; it is not causal evidence, not a fairness audit and not proof of production stability.",
    "forbidden_positive_claim_terms": [
      "causes churn",
      "caused churn",
      "causal driver",
      "because of platform",
      "proves retention effect",
      "fairness certified",
      "production stable"
    ],
    "required_limitation_labels": [
      "not_causal",
      "raw_margin_not_probability",
      "tree_path_dependent_background",
      "heldout_split_specific",
      "sensitive_to_correlated_features",
      "sensitive_to_bad_model_quality",
      "not_fairness_audit"
    ]
  },
  "warning_policy": {
    "high_cardinality_source": "categorical_feature_report",
    "correlation_threshold": 0.8,
    "min_background_rows_for_stable_explanations": 20,
    "min_explanation_rows_for_global_summary": 20,
    "min_tree_count_for_stable_explanations": 10,
    "max_baseline_log_loss_for_strong_claim": 0.693147,
    "flag_non_probability_output": true,
    "require_disagreement_table": true
  },
  "output": {
    "report_file": "shap_explanation_report.json",
    "global_summary_file": "shap_global_summary.csv",
    "local_explanations_file": "shap_local_explanations.csv",
    "additivity_audit_file": "shap_additivity_audit.csv",
    "disagreement_file": "explanation_disagreement.csv",
    "warning_ledger_file": "shap_warning_ledger.csv",
    "serialized_spec_file": "shap_explanation_serialized_spec.json"
  }
}
