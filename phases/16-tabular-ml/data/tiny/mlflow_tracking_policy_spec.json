{
  "mlflow_tracking_audit_id": "trial-churn-mlflow-tracking-audit-v0",
  "problem_id": "trial-churn-risk-7d-before-end",
  "baseline_package_id": "trial-churn-ml-baseline-package-v0",
  "source_optuna_tuning_audit_id": "trial-churn-optuna-tuning-audit-v0",
  "experiment": {
    "name": "trial_churn_tabular_ml_local_tracking_v0",
    "tracking_backend": "local_file_store",
    "tracking_package": "mlflow-skinny",
    "omit_raw_run_ids_from_exports": true
  },
  "tracking_scope": {
    "registry": false,
    "remote_tracking_server": false,
    "serving": false,
    "reason": "phase 16 uses local experiment history only; registry and serving belong outside this lesson"
  },
  "required_common_tags": [
    "mlflow_tracking_audit_id",
    "problem_id",
    "source_package_id",
    "optuna_tuning_audit_id",
    "decision_status",
    "readiness_status"
  ],
  "run_plan": [
    {
      "run_alias": "source_early_stopped_catboost",
      "run_name": "01_source_early_stopped_catboost",
      "run_role": "source_candidate",
      "model_id": "catboost_depth2_native_categories_es_logloss",
      "candidate_role": "source_before_tuning"
    },
    {
      "run_alias": "best_optuna_trial",
      "run_name": "02_best_optuna_trial",
      "run_role": "tuned_candidate",
      "model_id": "catboost_optuna_fixed_budget_logloss",
      "candidate_role": "best_validation_objective_trial"
    },
    {
      "run_alias": "phase15_baseline_cost_gate",
      "run_name": "03_phase15_baseline_cost_gate",
      "run_role": "baseline_gate",
      "model_id": "trial-churn-ml-baseline-package-v0",
      "candidate_role": "calibrated_baseline_gate"
    }
  ],
  "required_params": {
    "source_early_stopped_catboost": ["model_id", "model_family", "depth", "learning_rate", "random_seed"],
    "best_optuna_trial": ["model_id", "model_family", "depth", "learning_rate", "random_seed", "optuna_trial_number"],
    "phase15_baseline_cost_gate": ["model_id", "model_family", "baseline_package_id"]
  },
  "required_metrics": {
    "source_early_stopped_catboost": ["validation_logloss", "validation_top_k_total_error_cost"],
    "best_optuna_trial": [
      "validation_logloss",
      "validation_top_k_total_error_cost",
      "objective_improved_vs_source",
      "cost_gate_still_fails_vs_baseline"
    ],
    "phase15_baseline_cost_gate": ["validation_top_k_total_error_cost"]
  },
  "required_artifacts": {
    "source_early_stopped_catboost": [
      "upstream/optuna_best_trial_trace.csv",
      "model_metadata/source_early_stopped_catboost_model_metadata.json"
    ],
    "best_optuna_trial": [
      "upstream/optuna_tuning_serialized_spec.json",
      "upstream/optuna_trial_ledger.csv",
      "upstream/optuna_tuned_predictions.csv",
      "model_metadata/best_optuna_trial_model_metadata.json"
    ],
    "phase15_baseline_cost_gate": [
      "upstream/optuna_best_trial_trace.csv",
      "model_metadata/phase15_baseline_cost_gate_model_metadata.json"
    ]
  },
  "warning_policy": {
    "warn_if_cost_gate_still_fails": true,
    "warn_if_tracking_is_local_only": true,
    "warn_if_full_mlflow_package_conflicts_with_pandas3": true
  },
  "decision_policy": {
    "outcome_if_valid": "mlflow_ledger_ready_for_stability_package",
    "next_lesson_readiness": "ready_for_drift_and_stability_lesson"
  },
  "output": {
    "report_file": "mlflow_experiment_report.json",
    "run_table_file": "mlflow_run_table.csv",
    "artifact_inventory_file": "mlflow_artifact_inventory.csv",
    "metric_history_file": "mlflow_metric_history.csv",
    "reproducibility_checks_file": "mlflow_reproducibility_checks.csv",
    "model_metadata_file": "mlflow_model_metadata.json",
    "serialized_spec_file": "mlflow_tracking_serialized_spec.json"
  }
}
