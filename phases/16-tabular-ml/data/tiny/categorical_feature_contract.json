      "unknown_category_policy": "allow_native_catboost_unseen_value_and_monitor",
      "max_distinct_values_tiny": 5,
      "min_train_count_for_stable_level": 2
    },
    {
      "feature_name": "platform",
      "semantic_type": "stable_user_profile_attribute",
      "missing_policy": "missing_not_expected_block_if_seen",
      "unknown_category_policy": "allow_native_catboost_unseen_value_and_monitor",
      "max_distinct_values_tiny": 5,
      "min_train_count_for_stable_level": 2
    },
    {
      "feature_name": "country",
      "semantic_type": "stable_user_profile_attribute",
      "missing_policy": "missing_not_expected_block_if_seen",
      "unknown_category_policy": "allow_native_catboost_unseen_value_and_monitor",
      "max_distinct_values_tiny": 5,
      "min_train_count_for_stable_level": 2
    },
    {
      "feature_name": "acquisition_channel",
      "semantic_type": "stable_user_profile_attribute_with_structural_missing",
      "missing_policy": "map_missing_to_explicit_category",
      "unknown_category_policy": "allow_native_catboost_unseen_value_and_monitor",
      "max_distinct_values_tiny": 5,
      "min_train_count_for_stable_level": 2
    }
  ],
  "missing_category_token": "__MISSING__",
  "availability_policy": {
    "require_used_in_delivery_model": true,
    "require_candidate_allowed": true,
    "require_timing_allowed_by_policy": true,
    "require_source_allowed_by_problem": true
