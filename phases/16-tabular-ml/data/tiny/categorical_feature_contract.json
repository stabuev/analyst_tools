  "catboost_model_id": "catboost_depth2_native_categories",
  "fit_split": "train",
  "selection_split": "validation",
  "final_holdout_split": "test",
  "categorical_features": [
    {
      "feature_name": "plan_id",
      "semantic_type": "subscription_plan_at_prediction_time",
