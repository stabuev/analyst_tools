  "known_bad_categorical_candidates": [
    "segment_churn_rate_full_dataset",
    "churned_14d",
    "retention_offer_accepted"
  ],
  "output": {
    "report_file": "categorical_feature_report.json",
    "inventory_file": "categorical_inventory.csv",
    "unknowns_file": "categorical_unknowns.csv",
    "leakage_audit_file": "categorical_leakage_audit.csv",
    "serialized_contract_file": "categorical_serialized_contract.json"
  }
}
