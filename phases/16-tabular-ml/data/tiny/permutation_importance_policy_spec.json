{
  "permutation_importance_audit_id": "trial-churn-permutation-importance-audit-v0",
  "problem_id": "trial-churn-risk-7d-before-end",
  "catboost_baseline_id": "trial-churn-catboost-baseline-v0",
  "source_catboost_model_id": "catboost_depth2_native_categories",
  "early_stopping_model_id": "catboost_depth2_native_categories_es_logloss",
  "early_stopping_audit_id": "trial-churn-early-stopping-audit-v0",
  "categorical_audit_id": "trial-churn-categorical-feature-audit-v0",
  "built_in_importance_audit_id": "trial-churn-built-in-importance-audit-v0",
  "fit_split": "train",
  "heldout_split": "validation",
  "final_holdout_split": "test",
  "scoring": {
    "name": "neg_log_loss",
    "response_method": "predict_proba",
    "target_label_order": [0, 1],
    "greater_is_better": true,
    "importance_unit": "log_loss_increase_when_feature_is_permuted"
  },
  "permutation": {
    "n_repeats": 7,
    "random_state": 1605,
    "n_jobs": 1,
    "max_samples": 1.0,
    "feature_order_policy": "use_training_pool_feature_order"
  },
  "feature_name_policy": {
    "require_exact_feature_order": true,
    "expected_feature_order": [
      "sessions_14d",
      "active_days_14d",
      "support_tickets_14d",
      "revenue_30d",
      "days_since_signup",
      "had_support_ticket_14d",
      "plan_id",
      "platform",
      "country",
      "acquisition_channel"
    ]
  },
  "interpretation_policy": {
    "claim": "Permutation importance measures how held-out log loss changes when one feature column is shuffled for this trained CatBoost model; it is not evidence of causal impact or production stability.",
    "forbidden_positive_claim_terms": [
      "causes churn",
      "caused churn",
      "causal driver",
      "because of platform",
      "proves retention effect",
      "production stable"
    ],
    "required_limitation_labels": [
      "not_causal",
      "heldout_split_specific",
      "sensitive_to_correlated_features",
      "sensitive_to_bad_model_quality",
      "repeat_variance_visible"
    ]
  },
  "warning_policy": {
    "high_cardinality_source": "categorical_feature_report",
    "correlation_threshold": 0.8,
    "min_heldout_rows_for_stable_importance": 20,
    "max_baseline_log_loss_for_strong_claim": 0.693147,
    "require_positive_mean_minus_two_std_for_strong_claim": true
  },
  "output": {
    "report_file": "permutation_importance_report.json",
    "importance_file": "permutation_importance.csv",
    "repeat_file": "permutation_importance_repeats.csv",
    "warning_ledger_file": "permutation_warning_ledger.csv",
    "serialized_spec_file": "permutation_importance_serialized_spec.json"
  }
}
