{
  "package_id": "trial-churn-tabular-ml-interpretation-package-v0",
  "problem_id": "trial-churn-risk-7d-before-end",
  "source_baseline_package_id": "trial-churn-ml-baseline-package-v0",
  "source_mlflow_tracking_audit_id": "trial-churn-mlflow-tracking-audit-v0",
  "candidate_model_id": "catboost_optuna_fixed_budget_logloss",
  "source_catboost_model_id": "catboost_depth2_native_categories_es_logloss",
  "baseline_model_id": "random_forest_depth2_class_weight_balanced",
  "required_upstream_reports": [
    "baseline_package_report",
    "catboost_report",
    "categorical_report",
    "early_stopping_report",
    "built_in_importance_report",
    "permutation_importance_report",
    "shap_report",
    "segment_report",
    "cost_report",
    "optuna_report",
    "mlflow_report"
  ],
  "required_evidence_files": [
    "baseline_package_manifest",
    "catboost_comparison",
    "catboost_training_trace",
    "categorical_inventory",
    "categorical_leakage_audit",
    "categorical_unknowns",
    "built_in_importance",
    "permutation_importance",
    "shap_global_summary",
    "explanation_disagreement",
    "strong_model_segment_deltas",
    "strong_model_hidden_failure_slices",
    "decision_gate",
    "threshold_comparison",
    "optuna_trial_ledger",
    "optuna_best_trial_trace",
    "mlflow_run_table",
    "mlflow_artifact_inventory"
  ],
  "drift_policy": {
    "score_reference_split": "train",
    "score_watch_abs_mean_delta": 0.02,
    "score_watch_ks_like_gap": 0.5,
    "feature_watch_unseen_after_train_rate": 0.2,
    "feature_watch_high_cardinality": true
  },
  "stability_policy": {
    "required_explanation_views": [
      "CatBoost PredictionValuesChange",
      "Permutation importance",
      "Tree SHAP mean_abs"
    ],
    "importance_top_feature_must_be_named": true,
    "direction_conflict_requires_watch": true,
    "segment_hidden_failures_block_promotion": true,
    "small_n_segments_are_diagnostic_only": true
  },
  "decision_policy": {
    "allowed_statuses": [
      "promote_candidate_with_limits",
      "keep_baseline",
      "needs_more_data",
      "leakage_blocked",
      "unstable_explanations",
      "drift_watch_required",
      "inconclusive"
    ],
    "candidate_failed_gate_status": "keep_baseline",
    "monitoring_status_with_warnings": "drift_watch_required",
    "production_ready_allowed": false,
    "causal_claim_allowed": false,
    "serving_release_allowed": false
  },
  "output": {
    "package_file": "tabular_ml_package.json",
    "report_file": "tabular_ml_package_report.json",
    "evidence_matrix_file": "tabular_ml_evidence_matrix.csv",
    "score_drift_file": "score_drift.csv",
    "feature_drift_file": "feature_drift.csv",
    "importance_stability_file": "importance_stability.csv",
    "segment_stability_file": "segment_stability.csv",
    "stability_report_file": "stability_report.json",
    "interpretation_report_file": "interpretation_report.md",
    "decision_report_file": "decision_report.md",
    "manifest_file": "tabular_ml_package_manifest.json"
  }
}
