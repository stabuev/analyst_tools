{
  "built_in_importance_audit_id": "trial-churn-built-in-importance-audit-v0",
  "problem_id": "trial-churn-risk-7d-before-end",
  "catboost_baseline_id": "trial-churn-catboost-baseline-v0",
  "source_catboost_model_id": "catboost_depth2_native_categories",
  "early_stopping_model_id": "catboost_depth2_native_categories_es_logloss",
  "early_stopping_audit_id": "trial-churn-early-stopping-audit-v0",
  "categorical_audit_id": "trial-churn-categorical-feature-audit-v0",
  "fit_split": "train",
  "eval_split": "validation",
  "final_holdout_split": "test",
  "importance_methods": [
    {
      "method": "PredictionValuesChange",
      "method_label": "model_internal_prediction_change",
      "data_split": "model_structure",
      "requires_eval_data": false,
      "interpretation_scope": "model_internal_diagnostic_not_causal"
    },
    {
      "method": "LossFunctionChange",
      "method_label": "validation_loss_delta_when_feature_is_removed",
      "data_split": "validation",
      "requires_eval_data": true,
      "interpretation_scope": "model_internal_validation_diagnostic_not_causal"
    }
  ],
  "feature_name_policy": {
    "require_exact_feature_order": true,
    "expected_feature_order": [
      "sessions_14d",
      "active_days_14d",
      "support_tickets_14d",
      "revenue_30d",
      "days_since_signup",
      "had_support_ticket_14d",
      "plan_id",
      "platform",
      "country",
      "acquisition_channel"
    ]
  },
  "interpretation_policy": {
    "claim": "Built-in importance is a model-internal diagnostic for this trained CatBoost model, not evidence of business or causal impact.",
    "forbidden_positive_claim_terms": [
      "causes churn",
      "caused churn",
      "causal driver",
      "because of platform",
      "proves retention effect"
    ],
    "required_limitation_labels": [
      "not_causal",
      "model_specific",
      "sensitive_to_correlated_features",
      "sensitive_to_high_cardinality"
    ]
  },
  "warning_policy": {
    "high_cardinality_source": "categorical_feature_report",
    "correlation_threshold": 0.8,
    "min_tree_count_for_stable_importance": 10,
    "dominant_prediction_values_change_threshold": 90.0
  },
  "output": {
    "report_file": "built_in_importance_report.json",
    "importance_file": "built_in_importance.csv",
    "feature_name_audit_file": "feature_name_audit.csv",
    "warning_ledger_file": "importance_warning_ledger.csv",
    "serialized_spec_file": "built_in_importance_serialized_spec.json"
  }
}
