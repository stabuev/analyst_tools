{
  "cost_sensitive_decision_audit_id": "trial-churn-cost-sensitive-decision-audit-v0",
  "problem_id": "trial-churn-risk-7d-before-end",
  "baseline_package_id": "trial-churn-ml-baseline-package-v0",
  "baseline_model_id": "random_forest_depth2_class_weight_balanced",
  "candidate_model_id": "catboost_depth2_native_categories_es_logloss",
  "segment_analysis_audit_id": "trial-churn-strong-model-segment-audit-v0",
  "calibration_policy_id": "trial-churn-calibration-policy-v0",
  "analysis_split": "validation",
  "final_holdout_split": "test",
  "score_sources": {
    "baseline": {
      "score_column": "calibrated_score",
      "score_type": "calibrated_churn_probability",
      "calibration_status": "approved_phase15_validation_bin_map"
    },
    "catboost": {
      "score_column": "score",
      "score_type": "declared_uncalibrated_churn_probability",
      "calibration_status": "not_approved_for_candidate"
    }
  },
  "cost_policy": {
    "false_positive_cost": 1.0,
    "false_negative_cost": 5.0,
    "unit": "relative_error_cost"
  },
  "budget_policy": {
    "max_actions": 2,
    "selection_unit": "snapshot_id",
    "top_k_tie_breaker": [
      "score_desc",
      "snapshot_id_asc"
    ],
    "threshold_tie_breaker": [
      "min_total_error_cost",
      "max_recall",
      "min_action_count",
      "threshold_desc"
    ]
  },
  "threshold_policy": {
    "selection_data": "validation",
    "candidate_thresholds": [
      1.0,
      0.6,
      0.5,
      0.492308,
      0.3
    ],
    "allow_under_budget": true,
    "forbid_threshold_selection_on_test": true,
    "fixed_threshold_role": "diagnostic"
  },
  "decision_policy": {
    "promotion_requires_candidate_total_cost_lte_baseline": true,
    "promotion_requires_candidate_top_k_cost_lte_baseline": true,
    "promotion_requires_approved_candidate_calibration": true,
    "promotion_requires_no_segment_warnings": true,
    "outcome_if_failed": "do_not_promote_catboost_candidate",
    "outcome_if_passed": "promote_catboost_candidate_for_review",
    "next_lesson_readiness": "ready_for_optuna_lesson"
  },
  "interpretation_policy": {
    "claim": "This artifact compares risk-ranking decisions under a fixed threshold, a learned validation threshold and a top-k budget. It does not estimate the causal effect of a retention offer.",
    "forbidden_positive_claim_terms": [
      "proves retention offer effect",
      "causal effect",
      "safe to ship",
      "production ready"
    ]
  },
  "warning_policy": {
    "require_calibration_warning_for_candidate": true,
    "require_segment_warning_propagation": true,
    "require_no_causal_effect_boundary": true
  },
  "output": {
    "report_file": "cost_sensitive_decision_report.json",
    "decision_row_file": "cost_sensitive_decision_rows.csv",
    "threshold_comparison_file": "threshold_comparison.csv",
    "budget_impact_file": "budget_impact.csv",
    "decision_gate_file": "decision_gate.csv",
    "audit_file": "cost_sensitive_decision_policy_audit.csv",
    "serialized_spec_file": "cost_sensitive_decision_serialized_spec.json"
  }
}
