{
  "dataset_id": "phase_11_customer_revenue_extract",
  "profile": "tiny",
  "business_timezone": "Europe/Moscow",
  "tables": {
    "raw_users": {
      "grain": "one registered user",
      "primary_key": ["user_id"],
      "freshness_column": "updated_at",
      "columns": {
        "user_id": "string",
        "registered_at": "timestamp_tz",
        "country": "string",
        "platform": "string",
        "acquisition_channel": "string",
        "plan": "string",
        "is_deleted": "boolean",
        "updated_at": "timestamp_tz"
      }
    },
    "raw_events": {
      "grain": "one client or server event",
      "primary_key": ["event_id"],
      "freshness_column": "received_at",
      "columns": {
        "event_id": "string",
        "user_id": "string",
        "event_name": "string",
        "event_version": "integer",
        "occurred_at": "timestamp_tz",
        "received_at": "timestamp_tz",
        "platform": "string",
        "properties_json": "json_string"
      }
    },
    "raw_orders": {
      "grain": "one order or marketplace payment",
      "primary_key": ["order_id"],
      "freshness_column": "updated_at",
      "columns": {
        "order_id": "string",
        "user_id": "string",
        "ordered_at": "timestamp_tz",
        "status": "string",
        "currency": "string",
        "amount": "decimal",
        "updated_at": "timestamp_tz"
      }
    },
    "raw_order_items": {
      "grain": "one line item inside an order",
      "primary_key": ["order_id", "line_number"],
      "freshness_column": "loaded_at",
      "columns": {
        "order_id": "string",
        "line_number": "integer",
        "product_id": "string",
        "quantity": "integer",
        "unit_price": "decimal",
        "currency": "string",
        "loaded_at": "timestamp_tz"
      }
    },
    "raw_subscriptions": {
      "grain": "one subscription period",
      "primary_key": ["subscription_id"],
      "freshness_column": "updated_at",
      "columns": {
        "subscription_id": "string",
        "user_id": "string",
        "plan": "string",
        "status": "string",
        "started_at": "timestamp_tz",
        "ended_at": "timestamp_tz_nullable",
        "updated_at": "timestamp_tz"
      }
    },
    "raw_support_tickets": {
      "grain": "one support ticket",
      "primary_key": ["ticket_id"],
      "freshness_column": "created_at",
      "columns": {
        "ticket_id": "string",
        "user_id": "string",
        "created_at": "timestamp_tz",
        "topic": "string",
        "priority": "string",
        "status": "string"
      }
    },
    "raw_refunds": {
      "grain": "one refund event for an order",
      "primary_key": ["refund_id"],
      "freshness_column": "refunded_at",
      "columns": {
        "refund_id": "string",
        "order_id": "string",
        "refunded_at": "timestamp_tz",
        "currency": "string",
        "amount": "decimal",
        "reason": "string"
      }
    },
    "raw_currency_rates": {
      "grain": "one currency rate for one calendar date",
      "primary_key": ["currency", "rate_date"],
      "freshness_column": "loaded_at",
      "columns": {
        "currency": "string",
        "rate_date": "date",
        "rate_to_rub": "decimal",
        "loaded_at": "timestamp_tz"
      }
    }
  }
}
