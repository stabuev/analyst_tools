{
  "version": "1.0.0",
  "artifacts": [
    {
      "name": "route-advisor",
      "type": "cli",
      "path": "outputs/route_advisor.py",
      "description": "Рекомендует маршрут курса по типам желаемых задач и показывает неопределенность выбора.",
      "usage": "python3 outputs/route_advisor.py --answers product,product,basic,product,data --json",
      "phase": 0,
      "lesson": 1,
      "lesson_title": "Карта профессии аналитика",
      "source": "phases/00-entry-and-tools/01-profession-map/outputs"
    },
    {
      "name": "diagnostic-runner",
      "type": "cli",
      "path": "outputs/diagnostic_runner.py",
      "description": "Проверяет решение четырех диагностических задач по Python и SQL и формирует отчет по навыкам.",
      "usage": "python3 outputs/diagnostic_runner.py --submission code/main.py --format markdown",
      "phase": 0,
      "lesson": 2,
      "lesson_title": "Диагностика Python и SQL",
      "source": "phases/00-entry-and-tools/02-python-and-sql-diagnostic/outputs"
    },
    {
      "name": "file-audit",
      "type": "cli",
      "path": "outputs/file_audit.sh",
      "description": "Строит воспроизводимый Markdown-отчет о файлах каталога, их размере и расширениях.",
      "usage": "bash outputs/file_audit.sh --top 10 --output audit.md path/to/project",
      "phase": 0,
      "lesson": 3,
      "lesson_title": "Терминал и файловая система",
      "source": "phases/00-entry-and-tools/03-terminal-and-filesystem/outputs"
    },
    {
      "name": "git-history-check",
      "type": "cli",
      "path": "outputs/git_history_check.py",
      "description": "Проверяет учебный Git-репозиторий: историю, чистоту дерева, .gitignore и сфокусированность коммитов.",
      "usage": "python3 outputs/git_history_check.py path/to/project --format markdown",
      "phase": 0,
      "lesson": 4,
      "lesson_title": "Git: история аналитического проекта",
      "source": "phases/00-entry-and-tools/04-git-foundations/outputs"
    },
    {
      "name": "pr-review-packet",
      "type": "cli",
      "path": "outputs/pr_review_packet.py",
      "description": "Собирает локальный пакет pull request: commits, diff, описание и аналитический чек-лист ревью.",
      "usage": "python3 outputs/pr_review_packet.py path/to/project --base main --body PR.md",
      "phase": 0,
      "lesson": 5,
      "lesson_title": "Ветки, pull request и ревью",
      "source": "phases/00-entry-and-tools/05-branches-and-review/outputs"
    }
  ]
}
