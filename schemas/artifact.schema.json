{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Analyst Tools lesson artifact",
  "type": "object",
  "required": ["name", "type", "path", "description", "usage"],
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "type": {
      "enum": [
        "function",
        "sql",
        "dbt-model",
        "data-contract",
        "test-suite",
        "report-template",
        "notebook",
        "cli",
        "app",
        "model-card",
        "prompt",
        "skill",
        "checklist",
        "workflow",
        "tool"
      ]
    },
    "path": {"type": "string", "pattern": "^outputs/"},
    "description": {"type": "string", "minLength": 1},
    "usage": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
